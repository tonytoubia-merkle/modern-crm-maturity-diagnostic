# ============================================================
# Modern CRM Maturity Diagnostic — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# Get these from: https://app.supabase.com → Project Settings → API
# ------------------------------------------------------------

# Your Supabase project URL (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase service role key (KEEP SECRET — server-side only)
# Get from: Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# ADMIN DASHBOARD
# Set a strong password for /admin access
# ------------------------------------------------------------
ADMIN_PASSWORD=change-me-to-a-strong-password

# ------------------------------------------------------------
# APP URL (used for absolute URLs in PDF/share features)
# Set to your Vercel deployment URL in production
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
